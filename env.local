# Copy to .env.local for local testing with `vercel dev`.
# On Vercel, set these in Settings > Environment Variables instead.
# You only need keys for the providers whose models you actually select.

#OPENAI_API_KEY=sk-...
#ANTHROPIC_API_KEY=sk-ant-...
#GOOGLE_API_KEY=AIza...
#XAI_API_KEY=xai-...
#DEEPSEEK_API_KEY=sk-...
#MOONSHOT_API_KEY=sk-...
#ZHIPU_API_KEY=...
#DASHSCOPE_API_KEY=sk-...
